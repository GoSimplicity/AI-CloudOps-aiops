# 环境配置
ENV=development  # 可选值: development, production
DEBUG=false
LOG_LEVEL=INFO

# 敏感信息 - API密钥
LLM_PROVIDER=ollama
LLM_API_KEY=  # 使用 openai 时填写
LLM_BASE_URL=https://api.siliconflow.cn/v1  # 使用 openai 时生效
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=qwen2.5:3b

# 通知配置
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-url

# Tavily搜索API密钥
TAVILY_API_KEY=

# 外部服务
PROMETHEUS_HOST=prometheus:9090
REDIS_HOST=redis
REDIS_PORT=6379