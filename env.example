# 环境配置（环境变量优先于 config/config.yaml，建议仅在此覆写必要项）
ENV=development  # 可选: development, production
DEBUG=true
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# LLM（二选一：openai 或 ollama）。仅需填写必要项，其余从 config.yaml 读取
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3-14B
LLM_TASK_MODEL=Qwen/Qwen2.5-14B-Instruct
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_REQUEST_TIMEOUT=15
# 当 LLM_PROVIDER=ollama 时生效
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:3b

# 外部服务端点（常用覆写）
PROMETHEUS_HOST=127.0.0.1:9090
PROMETHEUS_TIMEOUT=30
K8S_IN_CLUSTER=false
K8S_CONFIG_PATH=deploy/kubernetes/config
K8S_NAMESPACE=default

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=false
REDIS_CONNECTION_TIMEOUT=5
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_NAME=cloudops

# RAG（向量检索）
RAG_VECTOR_DB_PATH=data/vector_db
RAG_COLLECTION_NAME=aiops-assistant
RAG_KNOWLEDGE_BASE_PATH=data/knowledge_base
RAG_RETRIEVE_K=12
RAG_SCORE_THRESHOLD=0.0
RAG_HYBRID_ENABLED=false
RAG_RERANKER_ENABLED=false
RAG_RERANKER_MODEL=bge-reranker-base
RAG_RERANKER_TOP_K=20
RAG_ITER_MAX_LOOPS=1
RAG_RETRY_CONFIDENCE_THRESHOLD=0.6
RAG_MMR_TOP_K=6
RAG_MMR_LAMBDA=0.7
RAG_ANSWER_MAX_CHARS=300
RAG_SOURCE_LIMIT=4

# RCA（根因分析）
RCA_DEFAULT_TIME_RANGE=30
RCA_MAX_TIME_RANGE=1440
RCA_ANOMALY_THRESHOLD=0.65
RCA_CORRELATION_THRESHOLD=0.7
RCA_REQUEST_OVERRIDE=false
# 覆盖默认动态指标：可以使用 JSON 数组或逗号分隔
# JSON 数组示例（推荐）：
# RCA_DEFAULT_METRICS=["container_cpu_usage_seconds_total","container_memory_working_set_bytes","container_network_receive_bytes_total","container_network_transmit_bytes_total","kube_pod_container_status_restarts_total","kube_pod_container_status_ready","kube_pod_container_status_running","kube_pod_container_status_terminated","kube_pod_container_status_waiting","kubelet_running_pod_count","kubelet_running_container_count","node_cpu_seconds_total","node_memory_MemFree_bytes","kube_deployment_status_replicas_unavailable"]
# 或逗号分隔：
# RCA_DEFAULT_METRICS=container_cpu_usage_seconds_total,container_memory_working_set_bytes,container_network_receive_bytes_total,container_network_transmit_bytes_total,kube_pod_container_status_restarts_total,kube_pod_container_status_ready,kube_pod_container_status_running,kube_pod_container_status_terminated,kube_pod_container_status_waiting,kubelet_running_pod_count,kubelet_running_container_count,node_cpu_seconds_total,node_memory_MemFree_bytes,kube_deployment_status_replicas_unavailable

# 日志采集
RCA_LOGS_ENABLED=false
RCA_LOGS_TAIL_LINES=200
RCA_LOGS_MAX_PODS=5
RCA_LOGS_INCLUDE_PREVIOUS=false

# 链路追踪/OTel/Jaeger
RCA_TRACING_ENABLED=false
RCA_TRACING_PROVIDER=jaeger
RCA_JAEGER_QUERY_URL=http://127.0.0.1:16686
RCA_TRACING_TIMEOUT=15
RCA_TRACING_SERVICE=
RCA_TRACING_MAX_TRACES=30

# 通知 / 可选集成
FEISHU_WEBHOOK=
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5

# MCP 服务（可选）
MCP_SERVER_URL=http://127.0.0.1:9000
MCP_TIMEOUT=120
MCP_MAX_RETRIES=3