ENV=production
DEBUG=false
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=WARNING

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3-14B
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_REQUEST_TIMEOUT=30

# Optional: Ollama
# OLLAMA_BASE_URL=http://ollama:11434/v1
# OLLAMA_MODEL=qwen2.5:3b

# Prometheus
PROMETHEUS_HOST=prometheus:9090
PROMETHEUS_TIMEOUT=60

# Kubernetes
K8S_IN_CLUSTER=true
K8S_NAMESPACE=aiops

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_DECODE_RESPONSES=false
REDIS_CONNECTION_TIMEOUT=10
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5

# MySQL
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=cloudops
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# RAG
RAG_VECTOR_DB_PATH=/app/data/vector_db
RAG_COLLECTION_NAME=aiops-assistant
RAG_KNOWLEDGE_BASE_PATH=/app/data/knowledge_base
RAG_RETRIEVE_K=12
RAG_SCORE_THRESHOLD=0.0
RAG_ANSWER_MAX_CHARS=300
RAG_SOURCE_LIMIT=4

# RCA / Tracing
RCA_REQUEST_OVERRIDE=true
RCA_LOGS_ENABLED=true
RCA_TRACING_ENABLED=true
RCA_TRACING_PROVIDER=jaeger
RCA_JAEGER_QUERY_URL=http://jaeger-query:16686
RCA_TRACING_TIMEOUT=20
RCA_TRACING_MAX_TRACES=50

# Notifications
NOTIFICATION_ENABLED=true
FEISHU_WEBHOOK=

# MCP
MCP_SERVER_URL=http://mcp:9000
MCP_TIMEOUT=180
MCP_MAX_RETRIES=5
